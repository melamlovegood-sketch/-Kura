VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PWA Web Push — VAPID 公钥（npx web-push generate-vapid-keys 生成）。
# 公钥放这里（客户端订阅用）；私钥放 Supabase Secrets 的 VAPID_PRIVATE_KEY，
# 并把同一公钥也设到 Secrets 的 VAPID_PUBLIC_KEY（Edge Function 签名用）。
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
